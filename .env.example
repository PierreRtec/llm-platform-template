# Copy this file to `.env` and fill in real values before running
# `docker compose up`. Every value below is an obvious placeholder
# ("changeme-*"); the repository must never contain a real secret.
#
# Variables map 1:1 to docker-compose.yml (section 3.1 of the design doc).
# `.env` itself is gitignored; only this example file is committed.

# --- Postgres (single instance, three logical databases: app / litellm / langfuse) ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=changeme-postgres-password

# --- LiteLLM gateway (self-hosted OpenAI-compatible router) ---
# Master key used both to authenticate against LiteLLM and as the app's
# LITELLM_API_KEY (see docker-compose.yml).
LITELLM_MASTER_KEY=changeme-litellm-master-key
# Provider keys consumed by gateway/litellm.config.yaml model groups.
# Only needed for real calls (manual testing, evals); integration tests
# run against docker-compose.ci.yml with LiteLLM mock_response, no keys required.
SCALEWAY_API_KEY=changeme-scaleway-api-key
MISTRAL_API_KEY=changeme-mistral-api-key
ANTHROPIC_API_KEY=changeme-anthropic-api-key

# --- App (FastAPI service) ---
# Static API key required in the X-API-Key header for /v1/* routes.
APP_API_KEY=changeme-app-api-key

# --- Langfuse (self-hosted tracing, read by the app to export OTel traces) ---
LANGFUSE_PUBLIC_KEY=changeme-langfuse-public-key
LANGFUSE_SECRET_KEY=changeme-langfuse-secret-key
